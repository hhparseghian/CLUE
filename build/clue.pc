prefix=/usr/local
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: CLUE
Description: Cross-platform Lightweight UI Engine
Version: 0.1.0
Cflags: -I${includedir}
Libs: -L${libdir} -lclue -lfreetype -lEGL -lGLESv2 -lxkbcommon -lm -lX11 -lwayland-client -lwayland-egl -ldrm -lgbm -linput -ludev
